<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings
	xmlns="http://xmlns.jcp.org/xml/ns/persistence/orm"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence/orm
          http://xmlns.jcp.org/xml/ns/persistence/orm_2_2.xsd"
	version="2.2">

	<entity class="com.entity.Employee" access="PROPERTY">
		<!-- Specifying <table> is optional. If <table> with name attribute is 
			not provided, then Hibernate will itself generate the table's name using 
			the Entity class's name. -->
		<table name="hbn_employee" />

		<attributes>
			<!-- <id> Element is used to specify the Primary Key for the DB table. -->
			<id name="employeedId"> <!-- Map the "employeedId" property in Entity class, to.. -->
				<column name="employee_id" /> <!-- .. to "employee_id" column in the DB table. -->
				<!-- (<column name=".."> is optional if Entity Field Name & DB Table 
					Column Name are the same. -->
			</id>

			<basic name="employeeName"> <!-- Map the "employeeName" property in Entity class, to.. -->
				<column name="employee_name" length="40" /> <!-- .. to "employee_name" column in the DB table. -->
			</basic>

			<basic name="employeeAddress"> <!-- Map the "employeeAddress" property in Entity class, to.. -->
				<column name="employee_address" length="160" /> <!-- .. to "employee_address" column in the DB table. -->
			</basic>

			<basic name="employeeSalary"> <!-- Map the "employeeSalary" property in Entity class, to.. -->
				<column name="employee_salary" /> <!-- .. to "employee_salary" column in the DB table. -->
			</basic>

		</attributes>
	</entity>

</entity-mappings>
